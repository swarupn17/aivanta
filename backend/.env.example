# ============================================================
# Aivanta backend API — copy to backend/.env and fill in.
# NEVER commit real secrets. backend/.env is gitignored.
# ============================================================

# ---- Server ----
PORT=4000
# Comma-separated list of allowed frontend origins. Use "*" only in dev.
CORS_ORIGIN="http://localhost:3000"
# Active exam cycle used when mapping subject -> exam on enrolment commit.
ACADEMIC_YEAR="2025-26"

# ---- Supabase (SAME project as the frontend) ----
# URL + anon key mirror the frontend's NEXT_PUBLIC_SUPABASE_* values.
SUPABASE_URL="https://YOUR-PROJECT.supabase.co"
SUPABASE_ANON_KEY="your-anon-public-key"
# Server-only. Bypasses Row-Level Security — used ONLY for public form leads
# (contact + registration). NEVER expose this to the browser.
SUPABASE_SERVICE_ROLE_KEY="your-service-role-key"
