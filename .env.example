# ============================================================
# Aivanta — environment variables (copy to .env.local and fill in)
# NEVER commit real secrets. .env.local is gitignored.
# ============================================================

# ---- Supabase ----
# Found in: Supabase Dashboard → Project Settings → API
NEXT_PUBLIC_SUPABASE_URL="https://YOUR-PROJECT.supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="your-anon-public-key"

# Server-only. Bypasses Row-Level Security — NEVER expose to the browser.
SUPABASE_SERVICE_ROLE_KEY="your-service-role-key"

# ---- Database (Drizzle migrations & server queries) ----
# Supabase → Project Settings → Database → Connection string.
# Use the "Session" pooler string for migrations; "Transaction" pooler for serverless runtime.
DATABASE_URL="postgresql://postgres:[PASSWORD]@db.YOUR-PROJECT.supabase.co:5432/postgres"

# ---- App ----
NEXT_PUBLIC_SITE_URL="http://localhost:3000"
