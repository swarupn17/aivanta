{
  "name": "aivanta",
  "version": "0.1.0",
  "private": true,
  "description": "Aivanta Scholar Foundation — olympiad & assessment platform (Next.js + Supabase).",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "typecheck": "tsc --noEmit",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "node --env-file-if-exists=.env.local ./node_modules/.bin/drizzle-kit migrate",
    "db:push": "node --env-file-if-exists=.env.local ./node_modules/.bin/drizzle-kit push",
    "db:studio": "node --env-file-if-exists=.env.local ./node_modules/.bin/drizzle-kit studio"
  },
  "dependencies": {
    "@hookform/resolvers": "^3.9.0",
    "@supabase/ssr": "^0.5.0",
    "@supabase/supabase-js": "^2.45.0",
    "clsx": "^2.1.1",
    "drizzle-orm": "^0.36.0",
    "exceljs": "^4.4.0",
    "next": "^16.2.9",
    "postgres": "^3.4.4",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-hook-form": "^7.53.0",
    "resend": "^6.17.2",
    "server-only": "^0.0.1",
    "tailwind-merge": "^2.5.4",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.1.0",
    "@tailwindcss/postcss": "^4.0.0",
    "@types/node": "^22.7.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "drizzle-kit": "^0.28.0",
    "eslint": "^9.13.0",
    "eslint-config-next": "^16.2.9",
    "postcss": "^8.4.47",
    "prettier": "^3.3.3",
    "prettier-plugin-tailwindcss": "^0.6.8",
    "tailwindcss": "^4.0.0",
    "typescript": "^5.6.0"
  },
  "allowScripts": {
    "sharp@0.34.5": true,
    "esbuild@0.18.20": true,
    "esbuild@0.19.12": true
  }
}
